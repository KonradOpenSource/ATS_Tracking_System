{
  "name": "@rx-angular/state",
  "version": "2.0.0",
  "description": "@rx-angular/state is a light-weight, flexible, strongly typed and tested tool dedicated to reduce the complexity of managing component state and side effects in angular",
  "main": "index.js",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=10.12.0",
    "npm": ">=5.3.0",
    "yarn": ">=1.9.2"
  },
  "author": "Michael Hladky <michael.hladky@push-based>",
  "homepage": "https://rx-angular.io/",
  "keywords": [
    "angular",
    "rxjs",
    "state",
    "ephemeral state",
    "component state",
    "state management",
    "performance",
    "state",
    "reactive state"
  ],
  "contributors": [
    {
      "name": "Michael Hladky",
      "email": "michael.hladky@push-based"
    },
    {
      "name": "Julian Jandl",
      "email": "julian@jandl.wien"
    },
    {
      "name": "Kirill Karnaukhov",
      "email": "karnaukhov.kh@gmail.com"
    },
    {
      "name": "Kajetan Świątek",
      "email": "kajetan.swiatek@gmail.com"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rx-angular/rx-angular.git"
  },
  "peerDependencies": {
    "@angular/core": ">=13.0.0",
    "rxjs": "^6.5.5 || ^7.4.0"
  },
  "dependencies": {
    "tslib": "^2.4.1",
    "ng-morph": "^2.1.3"
  },
  "ng-add": {
    "save": "dependencies"
  },
  "ng-update": {
    "migrations": "./schematics/migration.json"
  },
  "module": "fesm2015/state.mjs",
  "es2020": "fesm2020/state.mjs",
  "esm2020": "esm2020/state.mjs",
  "fesm2020": "fesm2020/state.mjs",
  "fesm2015": "fesm2015/state.mjs",
  "typings": "state.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./state.d.ts",
      "esm2020": "./esm2020/state.mjs",
      "es2020": "./fesm2020/state.mjs",
      "es2015": "./fesm2015/state.mjs",
      "node": "./fesm2015/state.mjs",
      "default": "./fesm2020/state.mjs"
    },
    "./actions": {
      "types": "./actions/rx-angular-state-actions.d.ts",
      "esm2020": "./esm2020/actions/rx-angular-state-actions.mjs",
      "es2020": "./fesm2020/rx-angular-state-actions.mjs",
      "es2015": "./fesm2015/rx-angular-state-actions.mjs",
      "node": "./fesm2015/rx-angular-state-actions.mjs",
      "default": "./fesm2020/rx-angular-state-actions.mjs"
    },
    "./effects": {
      "types": "./effects/state-effects.d.ts",
      "esm2020": "./esm2020/effects/state-effects.mjs",
      "es2020": "./fesm2020/state-effects.mjs",
      "es2015": "./fesm2015/state-effects.mjs",
      "node": "./fesm2015/state-effects.mjs",
      "default": "./fesm2020/state-effects.mjs"
    },
    "./selections": {
      "types": "./selections/state-selections.d.ts",
      "esm2020": "./esm2020/selections/state-selections.mjs",
      "es2020": "./fesm2020/state-selections.mjs",
      "es2015": "./fesm2015/state-selections.mjs",
      "node": "./fesm2015/state-selections.mjs",
      "default": "./fesm2020/state-selections.mjs"
    }
  },
  "sideEffects": false
}